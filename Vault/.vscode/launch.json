{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "manage.py runserver",
            "type": "debugpy",
            "request": "launch",
            "args": [
                "runserver"
            ],
            "django": true,
            "autoStartBrowser": false,
            "program": "${workspaceFolder}/manage.py"
        },
        {
            "name": "manage.py makemigrations",
            "type": "debugpy",
            "request": "launch",
            "args": [
                "makemigrations"
            ],
            "program": "${workspaceFolder}/manage.py"
        },
        {
            "name": "manage.py migrate",
            "type": "debugpy",
            "request": "launch",
            "args": [
                "migrate"
            ],
            "program": "${workspaceFolder}/manage.py"
        },
        {
            "name": "manage.py createsuperuser",
            "type": "debugpy",
            "request": "launch",
            "args": [
                "createsuperuser",
                "--noinput"
            ],
            "env": {
                "DJANGO_SUPERUSER_USERNAME": "admin",
                "DJANGO_SUPERUSER_PASSWORD": "admin",
                "DJANGO_SUPERUSER_EMAIL": "admin@localhost"
            },
            "program": "${workspaceFolder}/manage.py"
        },
        {
            "name": "manage.py shell",
            "type": "debugpy",
            "request": "launch",
            "args": [
                "shell"
            ],
            "program": "${workspaceFolder}/manage.py"
        },
        {
            "name": "manage.py dumpdata",
            "type": "debugpy",
            "request": "launch",
            "args": [
                "dumpdata",
                "--indent=4",
                "auth.user",
                "myapp"
            ],
            "program": "${workspaceFolder}/manage.py"
        },
        {
            "name": "manage.py loaddata",
            "type": "debugpy",
            "request": "launch",
            "args": [
                "loaddata",
                "--all"
            ],
            "program": "${workspaceFolder}/manage.py"
        },
        {
            "name": "manage.py cleardata",
            "type": "debugpy",
            "request": "launch",
            "args": [
                "cleardata",
            ],
            "program": "${workspaceFolder}/manage.py"
        }
    ]
}