{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Git Project Export",
            "type": "shell",
            "command": "git archive --format=zip --output project-export.zip HEAD",
            "problemMatcher": []
        },
        {
            "label": "Docker Build",
            "type": "shell",
            "command": "docker build . -t myapp",
            "problemMatcher": []
        },
        {
            "label": "Docker Create Volume",
            "type": "shell",
            "command": "docker volume create myapp-storage",
            "problemMatcher": []
        },
        {
            "label": "Docker Delete Volume",
            "type": "shell",
            "command": "docker volume rm myapp-storage",
            "problemMatcher": []
        },
        {
            "label": "Docker Run",
            "type": "shell",
            "command": "docker run -ti -v myapp-storage:/app/storage -p 8000:8000 --name mycontainer myapp",
            "problemMatcher": []
        },
        {
            "label": "Docker Clean",
            "type": "shell",
            "command": "docker rm mycontainer",
            "problemMatcher": []
        }
    ]
}
